{
  "name": "cragmark",
  "main": "worker.js",
  "compatibility_date": "2026-03-10",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cragmark-db",
      "database_id": "8fe6c671-a223-4bbd-978c-ae291f6d297b"
    }
  ]
}